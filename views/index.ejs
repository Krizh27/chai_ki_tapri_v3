<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chai ki Tapri</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&family=Sora:wght@600;700&display=swap"
    rel="stylesheet">

  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/themes.css">
  <link rel="stylesheet" href="/css/animations.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/home.css">

  <!-- Clerk Auth -->
  <script>
    const pubKey = "<%= clerkPublishableKey %>";
    const script = document.createElement('script');
    script.setAttribute('data-clerk-publishable-key', pubKey);
    script.async = true;
    script.src = 'https://cdn.jsdelivr.net/npm/@clerk/clerk-js@latest/dist/clerk.browser.js';
    script.crossOrigin = 'anonymous';
    
    script.addEventListener('load', async function() {
      try {
        await window.Clerk.load({
          appearance: {
            variables: {
              colorPrimary: '#f97316',
              colorBackground: '#1a1a1a',
              colorText: '#ffffff',
              colorInputBackground: '#2d2d2d',
              colorTextSecondary: '#a1a1aa'
            },
            elements: {
              userButtonAvatarBox: {
                width: '40px',
                height: '40px',
                border: '2px solid #f97316'
              }
            }
          }
        });
        
        const authContainer = document.getElementById('auth-container');
        if (authContainer) {
          if (window.Clerk.user) {
            window.Clerk.mountUserButton(authContainer);
          } else {
            authContainer.innerHTML = `
              <button onclick="window.Clerk.redirectToSignIn()" style="background: var(--color-orange-500); color: white; border: none; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(232, 124, 72, 0.3); transition: all 0.2s; font-family: inherit;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path><polyline points="10 17 15 12 10 7"></polyline><line x1="15" y1="12" x2="3" y2="12"></line></svg>
                Sign In
              </button>
            `;
          }
        }

        window.showToast = (message) => {
          let container = document.getElementById('toast-container');
          if (!container) {
            container = document.createElement('div');
            container.id = 'toast-container';
            container.style = "position: fixed; top: 80px; left: 50%; transform: translateX(-50%); z-index: 9999; display: flex; flex-direction: column; gap: 10px; transition: all 0.3s;";
            document.body.appendChild(container);
          }
          const toast = document.createElement('div');
          toast.style = "background: #ef4444; color: white; padding: 12px 24px; border-radius: 12px; font-weight: 600; font-size: 0.95rem; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4); display: flex; align-items: center; gap: 10px; opacity: 0; transform: translateY(-20px); transition: all 0.3s ease-out;";
          toast.innerHTML = `
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            ${message}
          `;
          container.appendChild(toast);
          
          requestAnimationFrame(() => {
            toast.style.opacity = '1';
            toast.style.transform = 'translateY(0)';
          });
          
          setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
          }, 3000);
        };

        window.handlePersonaClick = (e, url) => {
          if (!window.Clerk.user) {
            e.preventDefault();
            window.showToast("You need to sign up or sign in to start chatting!");
            setTimeout(() => window.Clerk.redirectToSignIn(), 1000);
          } else {
            window.location.href = url;
          }
        };

        window.handleStartChat = () => {
          if (!window.Clerk.user) {
            window.showToast("You need to sign up or sign in to start chatting!");
            setTimeout(() => window.Clerk.redirectToSignIn(), 1000);
          } else {
            document.querySelector('.persona-grid').scrollIntoView({ behavior: 'smooth' });
          }
        };

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('auth') === 'true' && !window.Clerk.user) {
          window.showToast("You need to sign up or sign in to start chatting!");
          setTimeout(() => window.Clerk.redirectToSignIn(), 1000);
          window.history.replaceState({}, document.title, "/");
        }
      } catch (err) {
        console.error('Error loading Clerk:', err);
      }
    });
    document.head.appendChild(script);
  </script>
</head>

<body class="dark-theme">

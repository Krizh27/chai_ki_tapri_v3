                  <path d="M29.053,46.103c-4.8,0-9.7-1-13.6-3c-0.3,0.4-0.4,0.7-0.4,1.1c0,2.6,7,4,13.9,4s13.9-1.4,13.9-4 c0-0.3-0.1-0.7-0.4-1C38.753,45.103,33.853,46.103,29.053,46.103z"/>
                  <path d="M29.353,7.903c-1.7,0-3.1,0.7-3.1,2.8h6.1C32.453,8.603,31.053,7.903,29.353,7.903z"/>
                  <path d="M55.553,15.403c-1.2-0.2-3.4-0.4-4.7,0.1c-1.8,0.7-2.6,2.2-3.6,3.4c-0.8,1-0.9,0.8-3.4,0.8 c-1.3-1.3-2.8-2.5-4.4-3.4c1.7-0.5,2.7-1.1,2.7-1.8c0-1.6-5.7-2.9-12.7-2.9s-12.7,1.3-12.7,2.9c0,0.6,0.9,1.2,2.5,1.7l0,0 c4.2,1.2,10.6,0.9,10.6,0.9s-3,1.9-13.8,1.1c-4.2,3.2-7.1,7.8-7.1,13c-0.1,9.5,10.1,13.8,20.1,13.8c10.1,0,20.2-4.3,20.2-13.8 c0-1.2-0.2-2.3-0.4-3.4c0.5-0.4,0.8-1.1,0.8-1.1c0.4-0.7,2.1-7,3.9-9c0.6-0.7,1.3-1.1,1.9-1.4 C56.253,15.803,56.353,15.503,55.553,15.403z"/>

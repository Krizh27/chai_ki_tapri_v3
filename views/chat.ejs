            <div>
              <div style="font-weight: 600; font-size: 1.1rem;">Chai Adda <span style="font-size:0.7em; color: var(--color-orange-500); background: rgba(181, 95, 48, 0.1); padding: 2px 6px; border-radius: 4px; margin-left: 6px;">BETA</span></div>

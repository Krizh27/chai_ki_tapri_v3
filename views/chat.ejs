            <div>
              <div id="chat-header-name" style="font-weight: 600; font-size: 1.1rem;"><%= persona === 'hitesh' ? 'Hitesh Choudhary' : 'Piyush Garg' %></div>
              <div class="status-indicator" style="font-size: 0.8rem; color: var(--text-muted); display: flex; align-items: center; gap: 6px;">
                <span class="status-dot" style="background-color: #4CAF50; width: 8px; height: 8px; border-radius: 50%; display: inline-block;"></span> Online
              </div>
            </div>
          <% } %>
        </div>
      </header>



      <div id="messages-container" class="chat-container">
        <!-- Messages injected by JS -->
      </div>

      <div class="input-container" style="padding: 0 24px 24px 24px; background: transparent; margin-top: auto;">
        <div class="input-wrapper" style="background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 16px; display: flex; flex-direction: row; align-items: flex-end; padding: 8px 12px; box-shadow: var(--shadow-sm); z-index: 2; position: relative; gap: 12px;">
          <textarea id="message-input" placeholder="Ask anything over chai..." rows="1" style="background: transparent; border: none; color: var(--text-primary); resize: none; font-family: inherit; font-size: 1rem; padding: 8px 0; min-height: 24px; max-height: 150px; outline: none; flex: 1; align-self: stretch;"></textarea>
          <div class="input-actions" style="display: flex; align-items: center; padding-bottom: 4px;">
            <div class="input-send-area" style="display: flex; align-items: center; gap: 12px;">
              <span class="send-hint hide-on-mobile" style="font-size: 0.75rem; color: var(--text-muted);">Enter to send</span>
              <button id="send-btn" class="send-btn" disabled style="background: var(--color-orange-500); color: white; border-radius: 8px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border: none; transition: opacity 0.2s; flex-shrink: 0;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              </button>
            </div>
          </div>
        </div>
        <% if (persona === 'adda') { %>
          <div style="text-align: center; margin-top: 8px; font-size: 0.75rem; color: var(--text-muted);">
            This feature is experimental and might not work properly.
          </div>
        <% } %>
      </div>
    </main>
  </div>
  </div>

  <!-- Modular Scripts -->

  <!-- Confirmation Modal -->
  <div id="confirm-modal" class="modal-overlay">
    <div class="modal-content">
      <h3 id="confirm-modal-title" style="margin-top:0; margin-bottom:12px; font-size:1.1rem; font-weight:600;">Confirm Action</h3>
      <p id="confirm-modal-message" style="color:var(--text-secondary); font-size:0.9rem; line-height:1.4; margin-bottom:24px;">Are you sure?</p>
      <div class="modal-actions" style="margin-top:0;">
        <button id="confirm-modal-cancel" class="btn-secondary" style="border:1px solid var(--border-color); cursor:pointer;">Cancel</button>
        <button id="confirm-modal-confirm" class="btn-danger" style="background-color:#ff6b6b; cursor:pointer; display: flex; align-items: center; gap: 6px; justify-content: center;">
          <svg width="18" height="18" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
            <path d="M160 256H96a32 32 0 0 1 0-64h256V95.936a32 32 0 0 1 32-32h256a32 32 0 0 1 32 32V192h256a32 32 0 1 1 0 64h-64v672a32 32 0 0 1-32 32H192a32 32 0 0 1-32-32V256zm448-64v-64H416v64h192zM224 896h576V256H224v640zm192-128a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32zm192 0a32 32 0 0 1-32-32V416a32 32 0 0 1 64 0v320a32 32 0 0 1-32 32z"/>
          </svg>
          Delete
        </button>
      </div>
    </div>
  </div>

  <script src="/js/ui-utils.js"></script>
  <script src="/js/storage.js"></script>
  <script src="/js/history.js"></script>
  <script src="/js/theme.js"></script>
  <script src="/js/chat-ui.js"></script>
  <script src="/js/sidebar.js"></script>
  <script src="/js/persona-switch.js"></script>
  <script src="/js/reset-chat.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>

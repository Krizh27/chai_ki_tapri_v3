                <g>
                  <path d="M6.553,30.003c-1.6-2.5-3.2-6.3-2.4-9c0.4-1.3,1.5-2.2,2.7-2.2c0.6,0,1.3,0.2,1.9,0.7 c0.6,0.5,1.1,1.2,1.5,1.9c0.2,0.3,0.4,0.6,0.6,0.8c1-1.6,2.3-3,3.9-4.3c-0.9-0.3-1.9-0.7-3-1.4c-1.7-1.1-3.8-1.8-5.7-1.8 c-1.6,0-4.6,0.5-5.7,4.1c-1,3.1,0.1,9.4,3.6,14.1c1.2,1.6,3,3.5,5.5,4.5c-0.9-1.7-1.5-3.6-1.6-5.7 C7.353,31.203,6.953,30.603,6.553,30.003z"/>

            </g>
          </svg>
        </div>
        <div>
          <h1 style="font-size: 1.25rem; font-weight: 600; color: var(--color-orange-500); margin: 0; line-height: 1.2;">Chai ki Tapri</h1>
          <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Pull up a chair. Grab a chai. Let's talk tech.</p>
        </div>
      </a>
      <div class="header-actions" style="display: flex; align-items: center; gap: 12px;">
        <% if (persona !== 'adda') { %>
          <div class="persona-segmented-control hide-on-mobile" style="display: flex; background: var(--bg-tertiary); border-radius: 20px; padding: 4px; border: 1px solid var(--border-color);">
            <button class="segment-btn <%= persona === 'hitesh' ? 'active' : '' %>" data-persona="hitesh" style="background: <%= persona === 'hitesh' ? 'var(--bg-secondary)' : 'transparent' %>; border: none; padding: 4px 12px; border-radius: 16px; font-size: 0.85rem; font-weight: 600; cursor: pointer; color: <%= persona === 'hitesh' ? 'var(--text-primary)' : 'var(--text-secondary)' %>; transition: 0.2s; box-shadow: <%= persona === 'hitesh' ? 'var(--shadow-sm)' : 'none' %>;">Hitesh</button>
            <button class="segment-btn <%= persona === 'piyush' ? 'active' : '' %>" data-persona="piyush" style="background: <%= persona === 'piyush' ? 'var(--bg-secondary)' : 'transparent' %>; border: none; padding: 4px 12px; border-radius: 16px; font-size: 0.85rem; font-weight: 600; cursor: pointer; color: <%= persona === 'piyush' ? 'var(--text-primary)' : 'var(--text-secondary)' %>; transition: 0.2s; box-shadow: <%= persona === 'piyush' ? 'var(--shadow-sm)' : 'none' %>;">Piyush</button>
